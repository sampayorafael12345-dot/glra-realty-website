# =============================================================
# GLRA Realty — Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit .env to git.
# =============================================================

# --- MongoDB ---
# Get a fresh connection string from MongoDB Atlas after rotating the password
MONGODB_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/glra_realty?retryWrites=true&w=majority

# --- JWT (used to sign admin login tokens) ---
# Generate a strong random secret, e.g. with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=8h

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Brevo (transactional email) ---
BREVO_API_KEY=your_brevo_api_key

# --- Anthropic (AI chatbot) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Default admin account (only used to seed the FIRST admin) ---
# After first login, change this in the admin panel and remove from .env.
ADMIN_EMAIL=admin@glrarealty.com
ADMIN_PASSWORD=change-me-on-first-login

# --- CORS allowed origins (comma-separated, no trailing slash) ---
# Production example: https://glrarealty.com,https://www.glrarealty.com
ALLOWED_ORIGINS=http://localhost:3000

# --- Server ---
PORT=3000
NODE_ENV=development
